[{'e}': 'return None\n\n# Global device identity\nDEVICE_IDENTITY = load_device_identity()\n\nclass GatewayConnection:', 'Manages connection to OpenClaw gateway"': 'def __init__(self', 'client_ws': 'WebSocket', 'thread_id': 'str):\n        self.client_ws = client_ws\n        self.thread_id = thread_id\n        self.gateway_ws: Optional[websockets.WebSocketClientProtocol] = None\n        self.connected = False\n        self.run_id: Optional[str] = None\n        \n    async def connect(self):', 'Connect to OpenClaw gateway"': 'logger.info(f', 'self.thread_id}': 'Start listening for gateway messages\n            asyncio.create_task(self._listen_to_gateway())\n            \n        except Exception as e:\n            logger.error(f', 'gateway': {'e}': 'raise\n    \n    async def _listen_to_gateway(self):', 'Listen for messages from OpenClaw gateway"': 'try:\n            async for message in self.gateway_ws:\n                try:\n                    data = json.loads(message)\n                    logger.debug(f', 'gateway': {'event" and data.get("event") == "connect.challenge': 'await self._handle_connect_challenge(data)\n                        continue\n                    \n                    # Forward to client\n                    await self._forward_to_client(data)\n                    \n                except json.JSONDecodeError:\n                    logger.error(f', 'gateway': {'message}': 'except websockets.exceptions.ConnectionClosed:\n            logger.info(f', 'self.thread_id}': 'except Exception as e:\n            logger.error(f', 'gateway': {'e}': 'finally:\n            self.connected = False\n    \n    async def _handle_connect_challenge(self', 'challenge_data': 'dict):', 'Handle connect.challenge event from gateway"': 'try:\n            nonce = challenge_data.get(', 'payload': {}, 'get("nonce': 'if not nonce:\n                logger.error(', 'logger.info(f': 'eceived connect.challenge with nonce: {nonce'}, 'DEVICE_IDENTITY': 'logger.error(', 'mission-